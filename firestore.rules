rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Meses de campaña — lectura pública, escritura solo admin autenticado
    match /herramax_2026/{mesId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Posts / publicaciones registradas — solo admin
    match /posts/{postId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if request.auth != null && isAdmin();
    }

    // Configuración global — solo admin
    match /config/{docId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if request.auth != null && isAdmin();
    }

    // Función helper: verifica que el email esté en la lista de admins
    function isAdmin() {
      return request.auth.token.email in [
        // AGREGA TU EMAIL AQUÍ:
        "tu-email@gmail.com"  // ← reemplaza con tu email real
      ];
    }
  }
}
